# Pixeltable live store. Shared with MARPA_PLATFORM and the rest of the
# /Volumes/PixelTable workspace.
PIXELTABLE_HOME=/Volumes/PixelTable/.pixeltable

# FastAPI sidecar transport. Bun calls this over a UNIX socket, never TCP,
# so the harness and the sidecar never expose a network port.
VWBRIDGE_SIDECAR_SOCKET=/tmp/vwbridge-pxt.sock
VWBRIDGE_SIDECAR_TOKEN=change-me-local-only

# iTwin OAuth (client credentials flow). Generate in the iTwin Developer
# Portal: https://developer.bentley.com/my-apps/
BENTLEY_CLIENT_ID=
BENTLEY_CLIENT_SECRET=
BENTLEY_TOKEN_URL=https://ims.bentley.com/connect/token
BENTLEY_SCOPES=itwin-platform
BENTLEY_API_BASE=https://api.bentley.com

# Default iTwin/iModel under analysis. Optional; can also be passed per-request.
BENTLEY_DEFAULT_ITWIN_ID=
BENTLEY_DEFAULT_IMODEL_ID=

# Optional: Qdrant mirror for the semantic_sidecars vector index. When
# unset, only Pixeltable's native embedding index is used.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=vwbridge_semantic_v1

# Embedding model (resolved by sentence-transformers). Pinned to an
# ungated, CPU-OK 768-d model so CI and offline laptops both work.
VWBRIDGE_EMBED_MODEL=sentence-transformers/all-mpnet-base-v2
