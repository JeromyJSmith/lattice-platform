# ---- secrets & local env ----
.env
.env.local
.env.*.local
*.local

# ---- JS / TS ----
node_modules/
dist/
dist-ssr/
.tanstack/
.vite/
.nitro/
.wrangler/
.output/
.vinxi/
__unconfig*
todos.json
*.tsbuildinfo

# ---- Python (sidecar) ----
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ---- Pixeltable runtime state (per-machine, never committed) ----
.pixeltable/
pixeltable/.bridge-idempotency.json

# ---- Local run artifacts ----
runtime-runs/
public/potree/
public/exports/
public/data/*.parquet
nohup.out
*.log

# ---- OS noise ----
.DS_Store
**/.DS_Store
Thumbs.db
.idea/
*.swp
*.swo

# ---- IDE worktree dust ----
.vscode/settings.json

# ---- Nested git repos (vendored skill bundles, etc.) ----
# Keep the content, exclude their upstream .git history.
.claude/skills/*/.git/

# ---- Local git worktrees ----
# .claude/worktrees/ holds git worktree checkouts of other branches.
# Each is a separate working tree with its own .git pointer file —
# committing them creates recursion since this worktree is itself inside.
.claude/worktrees/

# ---- Misc ----
*.tmp
*.bak
.cache/
.gstack/
