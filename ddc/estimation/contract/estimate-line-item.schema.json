{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.local/ddc/estimation/contract/estimate-line-item.schema.json",
  "title": "Estimate line item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "line_item_id",
    "project_id",
    "pricebook_item_id",
    "description",
    "quantity",
    "unit",
    "extended_price",
    "traceability"
  ],
  "properties": {
    "line_item_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "pricebook_item_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "quantity": { "type": "number", "minimum": 0 },
    "unit": { "type": "string", "minLength": 1 },
    "extended_price": { "type": "number", "minimum": 0 },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workbook_row_ref", "formula_refs", "source_artifact_ids"],
      "properties": {
        "workbook_row_ref": { "type": "string", "minLength": 1 },
        "formula_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "source_artifact_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
