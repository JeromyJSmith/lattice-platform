{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.local/schemas/agent-heavy-run-prompt.schema.json",
  "title": "Agent Heavy Run Prompt Schema",
  "description": "Machine-readable schema for bounded heavy-run execution prompts usable across Copilot and other agents.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prompt_schema_version",
    "prompt_id",
    "target_agent",
    "mode",
    "mission",
    "current_verified_state",
    "hard_rules",
    "allowed_paths",
    "disallowed_paths",
    "tasks",
    "validation_loop",
    "success_criteria",
    "report_contract"
  ],
  "properties": {
    "prompt_schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "prompt_id": {
      "type": "string",
      "pattern": "^PROMPT-[0-9]{8}-[A-Z0-9]{4,}$"
    },
    "target_agent": {
      "$ref": "#/$defs/target_agent"
    },
    "mode": {
      "$ref": "#/$defs/mode"
    },
    "mission": {
      "$ref": "#/$defs/mission"
    },
    "current_verified_state": {
      "$ref": "#/$defs/current_verified_state"
    },
    "hard_rules": {
      "$ref": "#/$defs/hard_rules"
    },
    "allowed_paths": {
      "$ref": "#/$defs/path_list"
    },
    "disallowed_paths": {
      "$ref": "#/$defs/path_list"
    },
    "tasks": {
      "$ref": "#/$defs/tasks"
    },
    "validation_loop": {
      "$ref": "#/$defs/validation_loop"
    },
    "success_criteria": {
      "$ref": "#/$defs/success_criteria"
    },
    "report_contract": {
      "$ref": "#/$defs/report_contract"
    }
  },
  "$defs": {
    "string_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "target_agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "surface",
        "invocation"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "type": "string",
          "minLength": 1
        },
        "invocation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_style",
        "autonomy",
        "permission_model"
      ],
      "properties": {
        "execution_style": {
          "type": "string",
          "enum": [
            "heavy_bounded_run",
            "bounded_run",
            "diagnostic_run"
          ]
        },
        "autonomy": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "permission_model": {
          "type": "string",
          "enum": [
            "no_intermediate_permission",
            "ask_when_blocked",
            "stepwise"
          ]
        }
      }
    },
    "mission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "objective",
        "repo_scope",
        "task_scope"
      ],
      "properties": {
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "repo_scope": {
          "type": "string",
          "minLength": 1
        },
        "task_scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "current_verified_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "facts"
      ],
      "properties": {
        "facts": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "hard_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment",
        "safety",
        "truthfulness"
      ],
      "properties": {
        "environment": {
          "$ref": "#/$defs/string_list"
        },
        "safety": {
          "$ref": "#/$defs/string_list"
        },
        "truthfulness": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "path_list": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "paths"
      ],
      "properties": {
        "paths": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "tasks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordered_steps"
      ],
      "properties": {
        "ordered_steps": {
          "$ref": "#/$defs/string_list"
        }
      }
    },
    "validation_loop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checks",
        "rerun_policy"
      ],
      "properties": {
        "checks": {
          "$ref": "#/$defs/string_list"
        },
        "rerun_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "success_criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "best_case",
        "acceptable_fallback"
      ],
      "properties": {
        "best_case": {
          "type": "string",
          "minLength": 1
        },
        "acceptable_fallback": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "report_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_fields"
      ],
      "properties": {
        "required_fields": {
          "$ref": "#/$defs/string_list"
        }
      }
    }
  }
}

