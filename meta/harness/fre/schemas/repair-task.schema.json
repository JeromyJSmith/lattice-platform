{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.local/meta/harness/fre/schemas/repair-task.schema.json",
  "title": "Repair Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "reason",
    "blocking_gate_ids",
    "acceptance_criteria",
    "owner"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^REPAIR-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "blocking_gate_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "harvest",
          "registry",
          "manifest",
          "verification",
          "state",
          "health",
          "promotion"
        ]
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    }
  }
}
