{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.local/meta/harness/fre/schemas/front-matter.schema.json",
  "title": "FRE front matter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "title",
    "doctype",
    "status",
    "version",
    "owner",
    "created_at",
    "updated_at",
    "comparison_engine_refs",
    "library_refs",
    "substrate_refs"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9-]+$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "doctype": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "status": {
      "type": "string",
      "pattern": "^[a-z-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "comparison_engine_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "library_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "substrate_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prompt_contract_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "related_docs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
