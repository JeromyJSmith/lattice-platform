{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lattice.local/meta/harness/fre/schemas/bridge-record.schema.json",
  "title": "Wrapper bridge record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "body_cell_id",
    "repo_root",
    "gate_id",
    "gate_version",
    "score",
    "status",
    "goal_path",
    "golden_path",
    "verifier_paths",
    "proof_artifacts",
    "blockers",
    "timestamp"
  ],
  "properties": {
    "body_cell_id": {
      "type": "string",
      "minLength": 1
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "gate_id": {
      "type": "string",
      "enum": [
        "harvest",
        "registry",
        "manifest",
        "verification",
        "state",
        "health",
        "promotion"
      ]
    },
    "gate_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "status": {
      "type": "string",
      "enum": [
        "red",
        "amber",
        "green"
      ]
    },
    "goal_path": {
      "type": "string",
      "minLength": 1
    },
    "golden_path": {
      "type": "string",
      "minLength": 1
    },
    "verifier_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "proof_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "comparison_engine": {
      "type": "string",
      "enum": [
        "infranodus"
      ]
    },
    "comparison_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "gate_id": {
            "enum": [
              "verification",
              "health",
              "promotion"
            ]
          }
        },
        "required": [
          "gate_id"
        ]
      },
      "then": {
        "required": [
          "comparison_engine",
          "comparison_artifacts"
        ]
      }
    }
  ]
}
