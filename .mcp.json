{
  "mcpServers": {
    "graphify": {
      "command": "bash",
      "args": [
        "/Volumes/PixelTable/VW_iTWIN_Bridge/VW_iTwin_Bridge/scripts/run-graphify-mcp.sh",
        "graphify-out/graph.json"
      ]
    },
    "gitnexus": {
      "command": "node",
      "args": ["node_modules/.bin/gitnexus", "mcp"]
    },
    "infranodus": {
      "command": "npx",
      "args": ["-y", "infranodus-mcp-server"],
      "env": {
        "INFRANODUS_API_KEY": "${INFRANODUS_API_KEY}"
      }
    },
    "n8n": {
      "command": "npx",
      "args": ["-y", "n8n-mcp"],
      "env": {
        "N8N_API_URL": "${N8N_API_URL}",
        "N8N_API_KEY": "${N8N_API_KEY}"
      }
    },
    "vectorworks": {
      "command": "uv",
      "args": [
        "run",
        "--with", "fastmcp",
        "/Volumes/PixelTable/VW_iTWIN_Bridge/VW_iTwin_Bridge/vw-python/mcp_bridge.py"
      ]
    },
    "vectorworks-github": {
      "command": "bash",
      "args": [
        "/Volumes/PixelTable/VW_iTWIN_Bridge/VW_iTwin_Bridge/scripts/run-vectorworks-github-mcp.sh"
      ]
    },
    "3d-asset-gen": {
      "command": "uv",
      "args": [
        "run",
        "--with", "fastmcp",
        "--with", "httpx",
        "/Volumes/PixelTable/VW_iTWIN_Bridge/VW_iTwin_Bridge/3d_assets/mcp_server.py"
      ],
      "env": {
        "PIXELTABLE_HOME": "/Volumes/PixelTable/.pixeltable",
        "PYTHONPATH": "/Volumes/PixelTable/schemas"
      }
    }
  }
}
