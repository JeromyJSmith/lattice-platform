OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
PIXELTABLE_SERVICE_URL=http://localhost:8765
PIXELTABLE_ENABLED=false
CLAUDE_CODE_BIN=claude
PI_BIN=pi
HERMES_BIN=hermes
RUNTIME_RUNS_DIR=./runtime-runs
# Replicate API token — required for TRELLIS image-to-3D generation
# Get one at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
# Optional: override the default TRELLIS model on Replicate
TRELLIS_MODEL=firtoz/trellis
